# Firebase Admin SDK (server-side)
# Generate at: Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"

# Firebase Client SDK (client-side, for reading data)
# Found at: Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Base URL for API calls during build (optional)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# NextAuth.js configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App credentials
# Create at: GitHub Settings > Developer settings > OAuth Apps
# Homepage URL: http://localhost:3000 (or production URL)
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# Anthropic API key (for AI category suggestions)
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

{
  "name": "@dis-tools/core",
  "version": "0.1.0",
  "description": "Core library for publiccode.yml validation and DIS-Readiness scoring",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cetriq/publiccode-tools.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Cetriq/publiccode-tools#readme",
  "bugs": {
    "url": "https://github.com/Cetriq/publiccode-tools/issues"
  },
  "type": "module",
